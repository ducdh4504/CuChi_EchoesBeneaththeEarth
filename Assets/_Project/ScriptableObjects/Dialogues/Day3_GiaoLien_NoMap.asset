  m_Script: {fileID: 11500000, guid: c543af8b5bd13fe48bebf92be6c07dfc, type: 3}
  m_Name: Day3_GiaoLien_NoMap
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: day3_giaolien_no_map
  dialogueTitle: "T\xECm b\u1EA3n \u0111\u1ED3 r\u1ED3i quay l\xEAn m\u1EB7t \u0111\u1EA5t"
  lines:
  - speakerName: "C\u1EF1u chi\u1EBFn binh"
    content: "Sao? Con t\xECm \u0111\u01B0\u1EE3c t\u1EA5m b\u1EA3n \u0111\u1ED3
      ch\u01B0a?"
  - speakerName: An
    content: "D\u1EA1... con v\u1EABn ch\u01B0a t\xECm th\u1EA5y, b\xE1c \u1EA1."
  - speakerName: "C\u1EF1u chi\u1EBFn binh"
    content: "V\u1EADy th\xEC con \u0111i t\xECm ti\u1EBFp \u0111i. Nh\u1EDB v\xE0o
      ph\xF2ng h\u1ECDp coi th\u1EED, b\u1EA3n \u0111\u1ED3 c\xF3 th\u1EC3 \u0111\u01B0\u1EE3c
      c\u1EA5t \u1EDF \u0111\xF3."
  - speakerName: "C\u1EF1u chi\u1EBFn binh"
    content: "T\xECm \u0111\u01B0\u1EE3c t\u1EA5m b\u1EA3n \u0111\u1ED3 r\u1ED3i
      th\xEC \u0111\u1EEBng n\u1EA5n n\xE1 d\u01B0\u1EDBi h\u1EA7m n\u1EEFa. Con
      h\xE3y quay l\xEAn m\u1EB7t \u0111\u1EA5t ngay \u0111\u1EC3 b\xE1o l\u1EA1i
      t\xECnh h\xECnh."
  - speakerName: An
    content: "D\u1EA1, con hi\u1EC3u r\u1ED3i. Con s\u1EBD t\xECm b\u1EA3n \u0111\u1ED3
      r\u1ED3i quay l\xEAn m\u1EB7t \u0111\u1EA5t."
  objectiveIdAfterDialogue: day3_find_map
  messageAfterDialogue: "T\xECm t\u1EA5m b\u1EA3n \u0111\u1ED3 trong ph\xF2ng h\u1ECDp,
    sau \u0111\xF3 quay l\xEAn m\u1EB7t \u0111\u1EA5t."
