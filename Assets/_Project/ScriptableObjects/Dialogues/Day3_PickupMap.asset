  dialogueTitle: "Nh\u1EB7t b\u1EA3n \u0111\u1ED3"
  lines:
  - speakerName: An
    content: "\u0110\xE2y r\u1ED3i! T\u1EA5m b\u1EA3n \u0111\u1ED3 m\xE0 m\xECnh
