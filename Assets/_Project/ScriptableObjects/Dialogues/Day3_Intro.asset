  m_Script: {fileID: 11500000, guid: c543af8b5bd13fe48bebf92be6c07dfc, type: 3}
  m_Name: Day3_Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: day3_intro
  dialogueTitle: "Sau khi gi\u1EA3i m\xE3"
  lines:
  - speakerName: An
    content: "M\xECnh \u0111\xE3 truy\u1EC1n tin xong r\u1ED3i. B\xE2y gi\u1EDD m\xECnh
      ph\u1EA3i ti\u1EBFp t\xFAc \u0111i t\xECm t\u1EA5m b\u1EA3n \u0111\u1ED3 m\u1EDBi
      \u0111\u01B0\u1EE3c."
    voiceClip: {fileID: 8300000, guid: 5eadb8cc6a219634ab17d0d8a2df3015, type: 3}
    delayAfterLine: 0.15
    fallbackDuration: 2.5
  - speakerName: An
    content: "N\u1EBFu c\xF3 t\u1EA5m b\u1EA3n \u0111\u1ED3 th\xEC ph\u1EA3i b\xE1o
      ngay cho giao li\xEAn k\u1EF3 c\u1EF1u m\u1EDBi \u0111\u01B0\u1EE3c. \u0110i
      th\xF4i kh\xF4ng c\xF2n nhi\u1EC1u th\u1EDDi gian"
    voiceClip: {fileID: 8300000, guid: 4919daea12864e746a3a7f3da04183a4, type: 3}
    delayAfterLine: 0.15
    fallbackDuration: 2.5
  objectiveIdAfterDialogue: 
  messageAfterDialogue: "T\xECm g\u1EB7p Giao Li\xEAn K\u1EF3 C\u1EF1u \u0111\u1EC3
    b\xE1o tin."
