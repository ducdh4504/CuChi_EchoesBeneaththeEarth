  m_Script: {fileID: 11500000, guid: c543af8b5bd13fe48bebf92be6c07dfc, type: 3}
  m_Name: Day3_Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: day3_intro
  dialogueTitle: "Sau khi gi\u1EA3i m\xE3"
  lines:
  - speakerName: An
    content: "M\xECnh \u0111\xE3 gi\u1EA3i m\xE3 \u0111\u01B0\u1EE3c r\u1ED3i...
      \u0111\xE2y l\xE0 tin c\u1EE7a \u0111\u1ECBch."
  - speakerName: An
    content: "Theo b\u1EA3n tin, s\xE1ng mai \u0111\u1ECBch s\u1EBD c\xE0n v\xE0o
      khu v\u1EF1c n\xE0y."
  - speakerName: An
    content: "Ph\u1EA3i b\xE1o ngay cho giao li\xEAn k\u1EF3 c\u1EF1u m\u1EDBi \u0111\u01B0\u1EE3c."
  - speakerName: An
    content: "\u0110i th\xF4i, kh\xF4ng c\xF2n nhi\u1EC1u th\u1EDDi gian."
  objectiveIdAfterDialogue: 
  messageAfterDialogue: "T\xECm g\u1EB7p Giao Li\xEAn K\u1EF3 C\u1EF1u \u0111\u1EC3
    b\xE1o tin."
