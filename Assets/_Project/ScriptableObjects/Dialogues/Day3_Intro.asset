  m_Script: {fileID: 11500000, guid: c543af8b5bd13fe48bebf92be6c07dfc, type: 3}
  m_Name: Day3_Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: day3_intro
  dialogueTitle: "Sau khi gi\u1EA3i m\xE3"
  lines:
  - speakerName: An
    content: "M\xECnh \u0111\xE3 truy\u1EC1n tin xong r\u1ED3i"
  - speakerName: An
    content: "B\xE2y gi\u1EDD m\xECnh ph\u1EA3i ti\u1EBFp t\xFAc \u0111i t\xECm t\u1EA5m
      b\u1EA3n \u0111\u1ED3 th\xF4i."
  - speakerName: An
    content: "B\xE2y gi\u1EDD m\xECnh ph\u1EA3i ti\u1EBFp t\xFAc \u0111i t\xECm t\u1EA5m
      b\u1EA3n \u0111\u1ED3 m\u1EDBi \u0111\u01B0\u1EE3c,n\u1EBFu c\xF3 t\u1EA5m
      b\u1EA3n \u0111\u1ED3 th\xEC ph\u1EA3i b\xE1o ngay cho giao li\xEAn k\u1EF3
      c\u1EF1u m\u1EDBi \u0111\u01B0\u1EE3c."
  - speakerName: An
    content: "\u0110i th\xF4i, kh\xF4ng c\xF2n nhi\u1EC1u th\u1EDDi gian."
  objectiveIdAfterDialogue: 
  messageAfterDialogue: "T\xECm g\u1EB7p Giao Li\xEAn K\u1EF3 C\u1EF1u \u0111\u1EC3
    b\xE1o tin."
